###############################
# Visual Studio (C++ / OpenGL)
###############################

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Visual Studio cache (these contain the huge ipch files)
.vs/
*.VC.db
*.VC.VC.opendb
*.ipch
.vs/SolarSystem
*.ipch
*.VC.db

###############################
# BUILD DIRECTORIES
###############################
[Bb]in/
[Oo]bj/
[Ll]og/
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
ARM/
ARM64/
Intermediate/

###############################
# BINARY OUTPUT (ignore)
###############################
*.ilk
*.pdb
*.exe
*.dll
*.so
*.exp

###############################
# COMPILER INTERMEDIATE FILES
###############################
*.iobj
*.idb
*.ipdb
*.tlog
*.pch
*.pchi
*.o
*.obj  # <-- EXCEPT model assets (handled below)
*.tmp
*.log

###############################
# CMAKE GENERATED FILES
###############################
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
Makefile

###############################
# KEEP YOUR ASSETS (IMPORTANT)
###############################

# ALLOW 3D model files
!*.obj   # keep Wavefront OBJ models
!*.mtl
!*.fbx
!*.gltf
!*.glb

# Allow libs you need for OpenGL
!*.lib
!*.a
!*.dll  # unless you want to ignore them—usually keep for external libraries

###############################
# OTHER OPTIONAL IGNORES
###############################
*.cachefile
*.opensdf
*.sdf
*.dbmdl
*.pidb
*.psess
*.vsp
*.vspscc

# macOS
.DS_Store

# Python notebook autosave
.ipynb_checkpoints/
